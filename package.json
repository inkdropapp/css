{
  "name": "@inkdropapp/css",
  "version": "0.9.2",
  "description": "The common stylesheets for Inkdrop",
  "license": "MIT",
  "author": "Takuya Matsuyama <t@inkdrop.app>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkdropapp/css.git"
  },
  "files": [
    "*.css",
    "*.ts",
    "variables.json"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "generate-variable-names": "node ./scripts/generate-variable-names.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepublishOnly": "npm run generate-variable-names"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "postcss": "^8.5.15",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "inkdrop-model": "^2.11.5"
  }
}
